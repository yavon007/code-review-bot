# PostgreSQL
POSTGRES_USER=reviewbot
POSTGRES_PASSWORD=change-this-to-a-long-random-password
POSTGRES_DB=reviewbot

# Gitea
GITEA_BASE_URL=https://gitea.example.com
GITEA_TOKEN=change-this-to-your-gitea-token
GITEA_WEBHOOK_SECRET=change-this-to-a-long-random-secret
BOT_NAME=gpt-review-bot

# AI reviewer
# 留空则使用 mock reviewer，只验证链路不调用模型。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REVIEW_MODEL=gpt-4.1
REVIEW_MAX_DIFF_BYTES=120000

# Worker
WORKER_POLL_INTERVAL=5s
WORKER_CONCURRENCY=1
