# PostgreSQL
# 生产推荐使用独立数据库或单独部署的 PostgreSQL，不随应用重复发布。
DATABASE_URL=postgres://reviewbot:change-this-to-a-long-random-password@postgres:5432/reviewbot?sslmode=disable

# 如果使用 docker-compose.db.yml 自建 PostgreSQL，这三个变量只给数据库 compose 使用。
POSTGRES_USER=reviewbot
POSTGRES_PASSWORD=change-this-to-a-long-random-password
POSTGRES_DB=reviewbot

# Gitea
GITEA_BASE_URL=https://gitea.example.com
GITEA_TOKEN=change-this-to-your-gitea-token
GITEA_WEBHOOK_SECRET=change-this-to-a-long-random-secret
BOT_NAME=gpt-review-bot

# AI reviewer
# 留空则使用 mock reviewer，只验证链路不调用模型。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REVIEW_MODEL=gpt-4.1
REVIEW_MAX_DIFF_BYTES=120000
REVIEW_EXCLUDE_PATHS=vendor/**,node_modules/**,dist/**,build/**,*.lock,*.min.js
REVIEW_FAIL_ON_HIGH=true
REVIEW_POST_INLINE_COMMENTS=false
REVIEW_MAX_FINDINGS=20

# Worker
WORKER_POLL_INTERVAL=5s
WORKER_CONCURRENCY=1
